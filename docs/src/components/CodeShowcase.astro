---
// Side-by-side terminal panel showcase
// Usage: <CodeShowcase leftTitle="file.yaml" rightTitle="output" leftHtml="..." rightHtml="..." />
interface Props {
  leftTitle: string;
  rightTitle: string;
  leftHtml: string;
  rightHtml: string;
}

const { leftTitle, rightTitle, leftHtml, rightHtml } = Astro.props;
---
<div class="showcase">
  <div class="showcase-panel">
    <div class="panel-header">
      <span class="panel-dot red"></span>
      <span class="panel-dot yellow"></span>
      <span class="panel-dot green"></span>
      <span class="panel-title">{leftTitle}</span>
    </div>
    <pre class="panel-code"><code set:html={leftHtml} /></pre>
  </div>
  <div class="showcase-arrow">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
  </div>
  <div class="showcase-panel">
    <div class="panel-header">
      <span class="panel-dot red"></span>
      <span class="panel-dot yellow"></span>
      <span class="panel-dot green"></span>
      <span class="panel-title">{rightTitle}</span>
    </div>
    <pre class="panel-code"><code set:html={rightHtml} /></pre>
  </div>
</div>

<style>
  .showcase {
    display: flex;
    align-items: center;
    gap: 1rem;
    max-width: 860px;
    margin: 0 auto 2.5rem;
  }

  .showcase-panel {
    flex: 1;
    background: #16161e;
    border: 1px solid #292e42;
    border-radius: 10px;
    overflow: hidden;
    min-width: 0;
  }

  .panel-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: #1a1b27;
    border-bottom: 1px solid #292e42;
  }

  .panel-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .panel-dot.red { background: #f7768e; }
  .panel-dot.yellow { background: #e0af68; }
  .panel-dot.green { background: #9ece6a; }

  .panel-title {
    margin-left: 8px;
    font-size: 0.75rem;
    color: #565f89;
    font-family: var(--sl-font-mono, monospace);
  }

  .panel-code {
    margin: 0;
    padding: 1rem 1.25rem;
    font-size: 0.8rem;
    line-height: 1.6;
    overflow-x: auto;
    color: #a9b1d6;
    font-family: var(--sl-font-mono, monospace);
  }

  .panel-code code {
    background: none;
    padding: 0;
    font-size: inherit;
  }

  /* Syntax highlighting */
  .panel-code :global(.hl-key) { color: #7aa2f7; }
  .panel-code :global(.hl-str) { color: #9ece6a; }
  .panel-code :global(.hl-changed) { color: #e0af68; }
  .panel-code :global(.hl-dim) { color: #565f89; }
  .panel-code :global(.hl-change) { color: #e0af68; font-weight: 700; }
  .panel-code :global(.hl-add) { color: #9ece6a; font-weight: 700; }
  .panel-code :global(.hl-repo) { color: #c0caf5; font-weight: 600; }
  .panel-code :global(.hl-old) { color: #f7768e; text-decoration: line-through; }
  .panel-code :global(.hl-new) { color: #9ece6a; }
  .panel-code :global(.hl-prompt) { color: #565f89; }
  .panel-code :global(.hl-cmd) { color: #c0caf5; }
  .panel-code :global(.hl-flag) { color: #bb9af7; }
  .panel-code :global(.hl-comment) { color: #565f89; font-style: italic; }

  .showcase-arrow {
    flex-shrink: 0;
    color: #3b4261;
  }

  /* Light theme */
  :global([data-theme='light']) .showcase-panel {
    background: #e9e9ed;
    border-color: #c4c8da;
  }

  :global([data-theme='light']) .panel-header {
    background: #d5d6db;
    border-color: #c4c8da;
  }

  :global([data-theme='light']) .panel-title {
    color: #8990b3;
  }

  :global([data-theme='light']) .panel-code {
    color: #3b4261;
  }

  :global([data-theme='light']) .panel-code :global(.hl-key) { color: #2e7de9; }
  :global([data-theme='light']) .panel-code :global(.hl-str) { color: #587539; }
  :global([data-theme='light']) .panel-code :global(.hl-changed) { color: #8c6c3e; }
  :global([data-theme='light']) .panel-code :global(.hl-dim) { color: #8990b3; }
  :global([data-theme='light']) .panel-code :global(.hl-change) { color: #8c6c3e; }
  :global([data-theme='light']) .panel-code :global(.hl-add) { color: #587539; }
  :global([data-theme='light']) .panel-code :global(.hl-repo) { color: #343b58; }
  :global([data-theme='light']) .panel-code :global(.hl-old) { color: #f52a65; }
  :global([data-theme='light']) .panel-code :global(.hl-new) { color: #587539; }
  :global([data-theme='light']) .panel-code :global(.hl-prompt) { color: #8990b3; }
  :global([data-theme='light']) .panel-code :global(.hl-cmd) { color: #343b58; }
  :global([data-theme='light']) .panel-code :global(.hl-flag) { color: #9854c5; }
  :global([data-theme='light']) .panel-code :global(.hl-comment) { color: #8990b3; }
  :global([data-theme='light']) .showcase-arrow { color: #b4b5b9; }

  /* Responsive: stack vertically on small screens */
  @media (max-width: 720px) {
    .showcase {
      flex-direction: column;
    }
    .showcase-arrow {
      transform: rotate(90deg);
    }
    .showcase-panel {
      width: 100%;
    }
  }
</style>
