---
// Terminal-styled container for demo GIF with light/dark theme support.
// Usage: <DemoTerminal />
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
---
<div class="demo-terminal">
  <img
    src={`${base}/demo.gif`}
    alt="gh-infra demo showing plan and apply workflow"
    class="demo-gif demo-dark"
    loading="eager"
  />
  <img
    src={`${base}/demo-light.gif`}
    alt="gh-infra demo showing plan and apply workflow"
    class="demo-gif demo-light"
    loading="eager"
  />
</div>

<style>
  .demo-terminal {
    max-width: 720px;
    margin: 1.5rem auto 2rem;
    background: #1a1b26;
    border-radius: 12px;
    padding: 12px;
    border: 1px solid #292e42;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .demo-gif {
    width: 100%;
    border-radius: 6px;
    display: block;
  }

  .demo-light {
    display: none;
  }

  /* Light theme */
  :global([data-theme='light']) .demo-terminal {
    background: #e1e2e7;
    border: 1px solid #c4c8da;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
  }

  :global([data-theme='light']) .demo-dark {
    display: none;
  }

  :global([data-theme='light']) .demo-light {
    display: block;
  }
</style>
