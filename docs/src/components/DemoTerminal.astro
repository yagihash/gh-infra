---
// Terminal-styled container for demo GIF with light/dark theme support.
// Usage: <DemoTerminal />
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
---
<div class="demo-terminal">
  <div class="terminal-chrome">
    <span class="dot red"></span>
    <span class="dot yellow"></span>
    <span class="dot green"></span>
  </div>
  <img
    src={`${base}/demo.gif`}
    alt="gh-infra demo showing plan and apply workflow"
    class="demo-gif demo-dark"
    loading="eager"
  />
  <img
    src={`${base}/demo-light.gif`}
    alt="gh-infra demo showing plan and apply workflow"
    class="demo-gif demo-light"
    loading="eager"
  />
</div>

<style>
  .demo-terminal {
    max-width: 720px;
    margin: 2rem auto 2rem;
    background: #16161e;
    border-radius: 10px;
    border: 1px solid #292e42;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
    overflow: hidden;
  }

  .terminal-chrome {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: #1a1b27;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dot.red { background: #f7768e; }
  .dot.yellow { background: #e0af68; }
  .dot.green { background: #9ece6a; }

  .demo-gif {
    width: 100%;
    display: block;
    margin: 0;
    padding: 0;
    vertical-align: bottom;
  }

  .demo-light {
    display: none;
  }

  /* Light theme */
  :global([data-theme='light']) .demo-terminal {
    background: #e9e9ed;
    border-color: #c4c8da;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
  }

  :global([data-theme='light']) .terminal-chrome {
    background: #d5d6db;
    border-color: #c4c8da;
  }

  :global([data-theme='light']) .demo-dark {
    display: none;
  }

  :global([data-theme='light']) .demo-light {
    display: block;
  }
</style>
