---
// Feature card grid for the landing page.
// Usage: <Features />
---
<div class="feature-table">
  <div class="feature-row">
    <div class="feature-cell">
      <div class="feature-card">
        <span class="feature-icon">Y</span>
        <div class="feature-title">YAML, not HCL</div>
        <div class="feature-desc">No new language to learn. Describe your repos in plain YAML.</div>
      </div>
    </div>
    <div class="feature-cell">
      <div class="feature-card">
        <span class="feature-icon">S</span>
        <div class="feature-title">No state file</div>
        <div class="feature-desc">GitHub is the source of truth. No drift. No state to manage.</div>
      </div>
    </div>
  </div>
  <div class="feature-row">
    <div class="feature-cell">
      <div class="feature-card">
        <span class="feature-icon">P</span>
        <div class="feature-title">Plan & Apply</div>
        <div class="feature-desc">Preview every change before it happens. Apply with confidence.</div>
      </div>
    </div>
    <div class="feature-cell">
      <div class="feature-card">
        <span class="feature-icon">G</span>
        <div class="feature-title">Just gh + a token</div>
        <div class="feature-desc">No apps. No servers. No infra. Just a gh extension.</div>
      </div>
    </div>
  </div>
  <div class="feature-row">
    <div class="feature-cell">
      <div class="feature-card">
        <span class="feature-icon">R</span>
        <div class="feature-title">RepositorySet</div>
        <div class="feature-desc">Manage repos at scale. Shared defaults, per-repo overrides.</div>
      </div>
    </div>
    <div class="feature-cell">
      <div class="feature-card">
        <span class="feature-icon">F</span>
        <div class="feature-title">File delivery</div>
        <div class="feature-desc">Distribute files across repos via push or pull request.</div>
      </div>
    </div>
  </div>
</div>

<style>
  .feature-table {
    display: table;
    table-layout: fixed;
    width: 100%;
    max-width: 860px;
    margin: 0 auto;
    border-spacing: 16px;
  }

  .feature-row {
    display: table-row;
  }

  .feature-cell {
    display: table-cell;
    width: 50%;
    vertical-align: top;
  }

  .feature-card {
    padding: 20px;
    height: 100%;
    background: #16161e;
    border: 1px solid #292e42;
    border-radius: 12px;
    transition: border-color 0.2s;
  }

  .feature-card:hover {
    border-color: #3b4261;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: linear-gradient(135deg, rgba(122, 162, 247, 0.15), rgba(187, 154, 247, 0.15));
    color: #7aa2f7;
    font-weight: 700;
    font-size: 0.85rem;
    font-family: var(--sl-font-mono, monospace);
    margin-bottom: 10px;
  }

  .feature-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: #c0caf5;
    margin-bottom: 4px;
  }

  .feature-desc {
    font-size: 0.8rem;
    color: #565f89;
    line-height: 1.5;
    min-height: calc(1.5em * 2);
  }

  /* Light theme */
  :global([data-theme='light']) .feature-card {
    background: #e9e9ed;
    border-color: #c4c8da;
  }

  :global([data-theme='light']) .feature-card:hover {
    border-color: #b4b5b9;
  }

  :global([data-theme='light']) .feature-icon {
    background: linear-gradient(135deg, rgba(97, 131, 187, 0.15), rgba(152, 84, 197, 0.15));
    color: #6183bb;
  }

  :global([data-theme='light']) .feature-title {
    color: #343b58;
  }

  :global([data-theme='light']) .feature-desc {
    color: #8990b3;
  }

  @media (max-width: 600px) {
    .feature-table,
    .feature-row,
    .feature-cell {
      display: block;
      width: 100%;
    }

    .feature-cell + .feature-cell {
      margin-top: 16px;
    }
  }
</style>
